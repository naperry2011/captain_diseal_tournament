# Postgres connection strings (Neon / Vercel Postgres).
# Copy to .env (gitignored) and fill in real values.
#
# DATABASE_URL: the POOLED (-pooler) connection — used by the running app at
#   runtime via the Prisma pg adapter. This is what you set in Vercel.
# DATABASE_URL_UNPOOLED: the DIRECT (non-pooler) connection — used by Prisma CLI
#   for schema operations (db push / migrate). Pooled/pgbouncer URLs are
#   unreliable for DDL. Optional locally; falls back to DATABASE_URL if unset.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# TMDB (Shows = TV + Movies). Get from https://www.themoviedb.org/settings/api
# TMDB_READ_TOKEN is the v4 Read Access Token (bearer, preferred);
# TMDB_API_KEY is the v3 key (used as a fallback). At least one is required for
# Shows/Movies search; without either, those tabs show "search unavailable".
TMDB_READ_TOKEN="your-tmdb-v4-read-access-token"
TMDB_API_KEY="your-tmdb-v3-api-key"

# IGDB (games). Needs a Twitch developer app: https://dev.twitch.tv/console
# IGDB auth is a Twitch OAuth client-credentials grant, so both values are
# required for game search; without them the game tab shows "coming soon".
TWITCH_CLIENT_ID="your-twitch-client-id"
TWITCH_CLIENT_SECRET="your-twitch-client-secret"

# Postgres connection strings (Neon / Vercel Postgres).
# Copy to .env (gitignored) and fill in real values.
#
# DATABASE_URL: the POOLED (-pooler) connection — used by the running app at
#   runtime via the Prisma pg adapter. This is what you set in Vercel.
# DATABASE_URL_UNPOOLED: the DIRECT (non-pooler) connection — used by Prisma CLI
#   for schema operations (db push / migrate). Pooled/pgbouncer URLs are
#   unreliable for DDL. Optional locally; falls back to DATABASE_URL if unset.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
